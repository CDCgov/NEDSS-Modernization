<?xml version="1.0" encoding="UTF-8"?><xsp:page language="java" xmlns:xsp="http://apache.org/xsp" xmlns:util="http://apache.org/xsp/util/2.0" xmlns:srt-codes="http://www.cdc.gov/nedss/GetSRTCodes/1.0" xmlns:session="http://apache.org/xsp/session/2.0" xmlns:nedss="http://www.cdc.gov/nedss/logicsheet/nedss" xmlns:xsp-response="http://apache.org/xsp/response/2.0" xmlns:xsp-request="http://apache.org/xsp/request/2.0">	<xsp:structure>		<xsp:include>gov.cdc.nedss.util.*</xsp:include>		<xsp:include>java.util.*</xsp:include>	</xsp:structure>	<content>		<xsp:attribute name="form">			<xsp-request:get-attribute name="formHref"/>		</xsp:attribute>		<javascript-files>			<import>ProcessingDecision.js</import>		</javascript-files>		<button-bar>			<right>				<label>Submit</label>				<javascript-action>OpenProcessingDecisionForSelectCondition();</javascript-action>			</right>			<right>				<label>Cancel</label>				<javascript-action>cancelForm('<xsp-request:get-attribute name="cancelButtonHref"/>&amp;personUID=<xsp-request:get-parameter name="personUID"/>&amp;tabNumber=3');</javascript-action>			</right>		</button-bar>		<tab>			<nedss:writeErrorMessages/>			<group name="Please select a condition:">				<line>					<element name="cancelURL" type="hidden">						<value>							<xsp-request:get-attribute name="cancelButtonHref"/>&amp;personUID=<xsp-request:get-parameter name="personUID"/>&amp;tabNumber=3'						</value>					</element>					<element name="STDConditions" type="hidden">						<value>							<xsp-request:get-attribute name="STDConditions"/>						</value>					</element>					<element name="ProcessingDecision" type="hidden"/>					<element name="investigationType" type="hidden"/>					<element name="CreateInvestigationFromSTDorHIVLab" type="hidden">						<value>							<xsp-request:get-attribute name="CreateInvestigationFromSTDorHIVLab"/>						</value>					</element>					<!--<element type="select" name="ccd" onchange="top.location.href = '/cocoon/nedss/investigation/' + document.forms['nedssForm'].ccd.options[document.forms['nedssForm'].ccd.options.selectedIndex].value + '?pageName=investigation'">-->				</line>				<xsp:logic>					String ca = (String)request.getAttribute("PrevContextAction");					if(ca!=null){						if(ca.equals("ViewDocument")){					</xsp:logic>					<line>						<element name="customElement" type="conditional-entry">													<controller type="select" name="ccd" length="50">																<validation type="required" name="Condition" error-code="ERR023"/>								<srt-options-string>									<xsp-request:get-attribute name="DSConditionCdDescString"/>								</srt-options-string>								<value>									<xsp-request:get-attribute name="selectedSTDCondition"/>								</value>							</controller>							<line>								<xsp:attribute name="trigger">									<xsp-request:get-attribute name="STDConditions"/>								</xsp:attribute>																			<element type="select" name="referralBasis" label="Referral Basis" length="50" onchange="changeReferralBasis(this);"> 									<xsp:attribute name="name">referralBasisName</xsp:attribute>									<validation type="requiredIfSTD" error-code="ERR023" name="Referral Basis"/>									<srt-options-string>										<srt-codes:getCodedValues>											<type>REFERRAL_BASIS_CREATE_PHDC</type>										</srt-codes:getCodedValues>									</srt-options-string>									<value>										<xsp-request:get-attribute name="referralBasisDocument"/>									</value>								</element>							</line>												</element>						<element name="isCreateInvFromViewDocument" type="hidden">							<value>								<xsp-request:get-attribute name="isCreateInvFromViewDocument"/>							</value>						</element>					</line>								<xsp:logic>					} else if(ca.equals("AddInvestigation")) {				</xsp:logic>				<line>					<element type="conditional-entry">					<controller type="select" name="ccd" length="50">					<value>						<xsp-request:get-attribute name="selectedSTDCondition"/>					</value>										<validation type="required" name="Condition" error-code="ERR023"/>						<srt-options-string>							<xsp-request:get-attribute name="DSConditionCdDescString"/>						</srt-options-string>						</controller>                        <line>							<xsp:attribute name="trigger">								<xsp-request:get-attribute name="STDConditions"/>							</xsp:attribute>							<xsp:attribute name="name">referralBasisName</xsp:attribute>                            <element type="select" name="referralBasis" label="Referral Basis" length="50">                                 <validation type="requiredIfSTD" error-code="ERR023" name="Referral Basis"/>                                <srt-options-string>									<srt-codes:getCodedValues>										<type>REFERRAL_BASIS_CREATE_INV</type>									</srt-codes:getCodedValues>								</srt-options-string>							</element>						</line>					</element>				</line>				<xsp:logic>}else{</xsp:logic>				<line>					<element type="select" name="ccd"  length="50" description="conditionCdDescTxt">						<validation type="required" name="condition" error-code="ERR023"/>						<srt-options-string>							<xsp-request:get-attribute name="DSConditionCdDescString"/>						</srt-options-string>					</element>				</line>				<xsp:logic>}}</xsp:logic>								<line>					<element name="ContextAction" type="hidden" onload="javascript:if(document.getElementById('nestedElementsControllerPayload')!=null){document.getElementById('nestedElementsControllerPayload').className='none';}">						<value>							<xsp-request:get-attribute name="ContextAction"/>						</value>					</element>										<element name="referralBasisDocument" type="hidden" >						<value>							<xsp-request:get-attribute name="referralBasisDocument"/>						</value>					</element>					<!--<element type="select" name="ccd" onchange="top.location.href = '/cocoon/nedss/investigation/' + document.forms['nedssForm'].ccd.options[document.forms['nedssForm'].ccd.options.selectedIndex].value + '?pageName=investigation'">-->				</line>			</group>		</tab>	</content></xsp:page>