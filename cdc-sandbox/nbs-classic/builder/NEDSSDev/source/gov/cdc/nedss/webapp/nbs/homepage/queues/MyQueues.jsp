<script>function myFunction(typeQueue) {    var input, filter, ul, li, a, i, txtValue;    input = document.getElementById("myInput"+typeQueue);    filter = input.value.toUpperCase();    ul = document.getElementById("myUL"+typeQueue);    li = ul.getElementsByTagName("li");    for (i = 0; i < li.length; i++) {        a = li[i].getElementsByTagName("a")[0];        txtValue = a.textContent || a.innerText;        if (txtValue.toUpperCase().indexOf(filter) > -1) {            li[i].style.display = "";        } else {            li[i].style.display = "none";        }    }}</script><style>* {  box-sizing: border-box;}#myInputPrivate {  background-image: url('magnify.jpg');  background-position: 5px 3px;  background-repeat: no-repeat;  width: 70%;  font-size: 16px;  /*padding: 12px 20px 12px 40px; It was causing issues in IE (ND-19620)*/  padding-left: 40px;  border: 1px solid #ddd;  margin-bottom: 12px;}#myInputPublic {  background-image: url('magnify.jpg');  background-position: 5px 3px;  background-repeat: no-repeat;  width: 70%;  font-size: 16px; /*padding: 12px 20px 12px 40px; It was causing issues in IE (ND-19620)*/  padding-left: 40px;  border: 1px solid #ddd;  margin-bottom: 12px;}#myULPrivate li a:hover:not(.header) {  background-color: #eee;}</style><nedss:dashlet id="myQueues" name="My Queues" 	    isDraggable="true" headerClass="header dd-multi-handle-${colIndex}" 	    contentStyle="height=${dashletHeight}px;"	    headerId="dd-handle-${colIndex}_${rowIndex}a">								<logic:notEmpty name="homepageForm" property="queueCollection">				<b><font color="#003470" style="text-decoration: underline;">Default Queues</font></b>						<br>						<ul style="margin-left:0.75em;">            <logic:iterate id="link" name="homepageForm" property="queueCollection">                <li style="list-style:circle; margin-bottom:6px;">                    <bean:write name="link" filter="false" />                 </li>            </logic:iterate>						</ul>					</logic:notEmpty>									<logic:notEmpty name="homepageForm" property="queueCollectionCustomPrivate">			<br>						            <b><font color="#003470" style="text-decoration: underline;">Private Custom Queues</font></b>			<br>			<br>			<input type="text" id="myInputPrivate" onkeyup="myFunction('Private')" placeholder="Search for private custom queues" title="Type in a queue name">									<ul style="margin-left:0.75em;" id="myULPrivate">            <logic:iterate id="link" name="homepageForm" property="queueCollectionCustomPrivate">                <li style="list-style:circle; margin-bottom:6px;">                    <bean:write name="link" filter="false" />                 </li>            </logic:iterate>			</ul>		</logic:notEmpty>						<logic:notEmpty name="homepageForm" property="queueCollectionCustomPublic">			            <br>			             <b><font color="#003470" style="text-decoration: underline;">Public Custom Queues</font></b>			<br>			<br>			<input type="text" id="myInputPublic" onkeyup="myFunction('Public')" placeholder="Search for public custom queues" title="Type in a queue name">						<ul style="margin-left:0.75em;"  id="myULPublic">			               <logic:iterate id="link" name="homepageForm" property="queueCollectionCustomPublic">                <li style="list-style:circle; margin-bottom:6px;">                    <bean:write name="link" filter="false" />                 </li>            </logic:iterate>								</ul>    </logic:notEmpty>        <logic:empty name="homepageForm" property="queueCollection">        There are no shortcuts available.    </logic:empty> </nedss:dashlet>