<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>gov.cdc.nbs</groupId>
  <artifactId>nndm</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <packaging>war</packaging>
  <properties>
    <maven.compiler.target>1.8</maven.compiler.target>
    <maven.compiler.source>1.8</maven.compiler.source>
  </properties>
  <dependencies>
    <dependency>
        <groupId>nndm</groupId>
        <artifactId>nndm</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <type>jar</type>
    </dependency>
  </dependencies>
  <build>
  	<finalName>${project.artifactId}</finalName>
    <sourceDirectory>source/gov/cdc/nedss/webapp/nndm/WEB-INF/</sourceDirectory>
    <directory>target-nndm-war</directory>
    <plugins>
    	<plugin>    
	        <artifactId>maven-compiler-plugin</artifactId>
	        <configuration>
	            <source>1.8</source>
	            <target>1.8</target>
	        </configuration>
	    </plugin>
	    <plugin>
	      <artifactId>maven-war-plugin</artifactId>
		    <version>2.4</version>
		    <configuration>
            	<finalName>nndm</finalName>
            	<webXml>source/gov/cdc/nedss/webapp/nndm/WEB-INF/web.xml</webXml>
            	<webResources>
		            <resource>
		            	<directory>source/gov/cdc/nedss/webapp/nndm/WEB-INF/</directory>
		              	<targetPath>WEB-INF/</targetPath>
		              	<includes>
			                <include>jboss-web.xml</include>
		              	</includes>
		              	<excludes>
		                	<exclude>/nndm/WEB-INF/classes</exclude>
		              	</excludes>
		            </resource>
		        </webResources>  
                <modules>
                    <jarModule>
                        <groupId>nndm</groupId>
                        <artifactId>nndm</artifactId>
                        <bundleFileName>nndm</bundleFileName>
                        <uri>WEB-INF/lib/nndm.jar</uri>
                    </jarModule>
                </modules>
            </configuration>
	    </plugin>
    </plugins>
  </build>
</project>